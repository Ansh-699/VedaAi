# ─── Backend ───────────────────────────────────────────────
PORT=4000
NODE_ENV=development
CORS_ORIGIN=http://localhost:3000

MONGODB_URI=mongodb+srv://USER:PASS@CLUSTER.mongodb.net/vedai?retryWrites=true&w=majority
REDIS_URL=redis://default:PASS@HOST:PORT

# ─── AI Provider ───────────────────────────────────────────
# Options: kiro | mock
# Kiro runs via the `kiro-cli` binary in headless mode; install it with:
#   curl -fsSL https://cli.kiro.dev/install | bash
AI_PROVIDER=kiro

# Kiro CLI authentication. Get this from your Kiro account settings.
# Headless mode picks up KIRO_API_KEY automatically — no browser login needed.
KIRO_API_KEY=

# Optional: override the model Kiro CLI uses (e.g. claude-sonnet-4-5).
# Leave empty to use the CLI default.
KIRO_MODEL=

# Number of generations a single worker can run in parallel.
WORKER_CONCURRENCY=2

# ─── Frontend (Next.js) ────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_WS_URL=ws://localhost:4000/ws
